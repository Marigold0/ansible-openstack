[global]
fsid = {{ ceph_fsid }}
mon_initial_members = {{ inventory_hostname }}
mon_host = {{ internal_ip }}
auth_cluster_required = cephx
auth_service_required = cephx
auth_client_required = cephx
public_network = {{ ceph_public_network }}
cluster_network = {{ ceph_cluster_network }}

[client.rgw.{{ inventory_hostname }}]
host = {{ inventory_hostname }}
keyring = /var/lib/ceph/radosgw/ceph-rgw.{{ inventory_hostname }}/keyring
log file = /var/log/ceph/ceph-rgw-{{ inventory_hostname }}.log
rgw frontends = "beast endpoint={{ internal_ip }}:7480"
rgw thread pool size = 512

